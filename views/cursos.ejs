<%- include('partials/head', { title: 'Cursos | SAMU 192', extraCss: ['/front/css/cursos.css'] }) %>
    <%- include('partials/header', { active: 'cursos' }) %>

        <main class="courses-main">
            <section class="courses-hero" aria-label="Destaque dos cursos do SAMU">
                <div class="courses-hero-card">
                    <div>
                        <p class="section-tag">Protótipo da página</p>
                        <h1>Página Cursos com foco em primeiros socorros e conteúdo educacional</h1>
                        <p class="courses-intro">
                            Estrutura pensada para documentação no Figma, com hero, cards de categorias, frame principal do curso, trilha de aprendizado e CTA final.
                        </p>
                    </div>

                    <div class="courses-hero-side">
                        <div class="hero-mini-card">
                            <span>Bloco Hero</span>
                        </div>
                        <div class="hero-mini-card">
                            <span>Cards de apoio</span>
                        </div>
                    </div>
                </div>
            </section>

            <section class="course-overview" aria-label="Estrutura do protótipo">
                <article class="overview-card">
                    <span class="overview-card__label">Seção 01</span>
                    <h2>Banner principal do curso</h2>
                    <p>Área para título, resumo, CTA e imagem principal.</p>
                </article>

                <article class="overview-card">
                    <span class="overview-card__label">Seção 02</span>
                    <h2>Categorias ou filtros</h2>
                    <p>Espaço para módulos, tags, duração ou nível do curso.</p>
                </article>

                <article class="overview-card">
                    <span class="overview-card__label">Seção 03</span>
                    <h2>Curso em destaque</h2>
                    <p>Frame central para uma aula principal com apoio visual.</p>
                </article>
            </section>

            <section class="heimlich-section" aria-label="Manobra de Heimlich">
                <div class="section-heading">
                    <p class="section-tag">Curso em destaque</p>
                    <h2>Manobra de Heimlich</h2>
                    <p>
                        Frame principal do protótipo para documentar no Figma um curso visual, com área de mídia, informações laterais e passo a passo.
                    </p>
                </div>

                <div class="heimlich-frame">
                    <div class="frame-header">
                        <span>Frame educativo</span>
                        <span>Curso principal</span>
                    </div>

                    <div class="heimlich-content">
                        <div class="heimlich-visual">
                            <div class="visual-placeholder">
                                <span>Área visual do curso</span>
                            </div>
                        </div>

                        <div class="heimlich-steps">
                            <article class="step-card">
                                <strong>1. Identifique o engasgo</strong>
                                <p>
                                    A pessoa não consegue falar, tossir ou respirar normalmente e pode levar as mãos ao pescoço.
                                </p>
                            </article>

                            <article class="step-card">
                                <strong>2. Posicione-se atrás</strong>
                                <p>
                                    Fique atrás da vítima e envolva a cintura com os braços para ter firmeza na aplicação.
                                </p>
                            </article>

                            <article class="step-card">
                                <strong>3. Localize as mãos</strong>
                                <p>
                                    Feche uma das mãos em punho e coloque-a acima do umbigo, abaixo do osso do peito.
                                </p>
                            </article>

                            <article class="step-card">
                                <strong>4. Faça compressões para dentro e para cima</strong>
                                <p>
                                    Puxe rapidamente em movimentos curtos até o objeto sair ou a vítima voltar a respirar.
                                </p>
                            </article>
                        </div>
                    </div>
                </div>
            </section>

            <section class="learning-path" aria-label="Trilha de aprendizado">
                <div class="section-heading">
                    <p class="section-tag">Fluxo sugerido</p>
                    <h2>Trilha de aprendizado do aluno</h2>
                    <p>
                        Protótipo de uma linha de módulos que pode ser representada no Figma como cards, timeline ou etapas.
                    </p>
                </div>

                <div class="learning-path__grid">
                    <article class="path-card">
                        <span class="path-card__step">Módulo 01</span>
                        <h3>Introdução</h3>
                        <p>Resumo do curso, objetivos e contexto de emergência.</p>
                    </article>

                    <article class="path-card">
                        <span class="path-card__step">Módulo 02</span>
                        <h3>Reconhecimento</h3>
                        <p>Sinais de engasgo leve e grave para orientar a conduta.</p>
                    </article>

                    <article class="path-card">
                        <span class="path-card__step">Módulo 03</span>
                        <h3>Execução</h3>
                        <p>Aplicação da manobra com segurança e posicionamento correto.</p>
                    </article>

                    <article class="path-card">
                        <span class="path-card__step">Módulo 04</span>
                        <h3>Pós-atendimento</h3>
                        <p>Encaminhamento, observação e acionamento do SAMU 192.</p>
                    </article>
                </div>
            </section>

            <section class="extra-courses" aria-label="Outros cursos">
                <article class="course-card">
                    <h3>Card de curso secundário</h3>
                    <p>Espaço para miniatura, título, breve descrição e status.</p>
                </article>

                <article class="course-card">
                    <h3>Card de curso secundário</h3>
                    <p>Espaço para miniatura, título, breve descrição e status.</p>
                </article>

                <article class="course-card">
                    <h3>Card de curso secundário</h3>
                    <p>Espaço para miniatura, título, breve descrição e status.</p>
                </article>
            </section>

            <section class="prototype-cta" aria-label="Encerramento do protótipo">
                <div class="prototype-cta__box">
                    <div>
                        <p class="section-tag">Seção final</p>
                        <h2>Call to action para inscrição ou acesso à aula</h2>
                        <p>
                            Bloco pensado para a parte inferior da página, útil para documentar botão principal, benefícios e observações.
                        </p>
                    </div>
                    <div class="prototype-cta__button">Botão / CTA principal</div>
                </div>
            </section>
        </main>

        <%- include('partials/footer') %>